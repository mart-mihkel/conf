#!/usr/bin/env bash

log() { printf "\033[1;34m[%s]\033[0m %s\n" "$(date '+%H:%M:%S')" "$*"; }

WALLS=~/.cache/rice/walls
ICONS=~/.cache/rice/icons

mkdir -p $WALLS
mkdir -p $ICONS

log "creating thumbnails..."
for WP in $WALLS/*; do
    ICO=$ICONS/$(basename $WP)
    if [[ -f $ICO ]]; then
        continue
    fi

    log "cropping $(basename $WP)..."
    magick convert \
        -quiet \
        -strip $WP \
        -thumbnail x500^ \
        -gravity center \
        -extent 500x500 \
        $ICO 2>/dev/null
done

IMG=$(
    for WP in $WALLS/*; do
        printf "$WP\0icon\x1f$ICONS/$(basename $WP)\n"
    done | rofi -dmenu -config ~/.config/rofi/walls.rasi
)

if [[ -z $IMG ]]; then
    log "pick cancelled"
    exit 1
fi

log "setting wallpaper"
awww img $IMG -t none

case $IMG in
    *-light*) MODE=-m\ light ;;
    *-dark*) MODE=-m\ dark ;;
    *) MODE= ;;
esac

log "generating colors"
matugen image $IMG $MODE --prefer saturation
dunstctl reload
