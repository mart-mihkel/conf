#!/usr/bin/env bash

log() { printf "\033[1;34m[%s]\033[0m %s\n" "$(date '+%H:%M:%S')" "$*"; }

PROJECT=$(
    fdfind -d 1 -t d . ~/git | \
    fzf --gutter " " --pointer " " --delimiter / --with-nth "{5}"
)

if [[ -z $PROJECT ]]; then
    log "no project selected"
    exit 1
fi

SESSION=$(basename $PROJECT | tr . _)

if ! tmux has-session -t $SESSION 2>/dev/null; then
    log "starting tmux session for $SESSION"
    tmux new-session -d -s $SESSION -c $PROJECT
fi

if [[ -n $TMUX ]]; then
    log "attaching current client to session"
    CLIENT=$(tmux display-message -p "#{client_name}")
    tmux switch-client -c $CLIENT -t $SESSION
else
    log "attaching to session"
    tmux attach-session -t $SESSION
fi
