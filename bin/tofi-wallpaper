#!/usr/bin/env bash

log() { printf "\033[1;34m[%s]\033[0m %s\n" "$(date '+%H:%M:%S')" "$*"; }

WALLS=~/.cache/rice/walls
PICK=$(ls $WALLS | tofi --prompt-text img:)
IMG=$WALLS/$PICK

if [[ -z $PICK ]]; then
    log "Pick cancelled"
    exit 1
fi

log "Setting wallpaper"
awww img $IMG --transition-type grow --transition-fps 60

if [[ "${1:-}" != "--hellwal" ]]; then
    log "Skipping color generation"
    exit 0
fi

log "Generating colors"

HWAL=~/.cache/hellwal
CFG=~/.config

case $PICK in
    light-*) HWAL_MODE=--light ;;
    dark-*) HWAL_MODE=--dark ;;
    *) HWAL_MODE= ;;
esac

hellwal --quiet --skip-term-colors $HWAL_MODE --image $IMG

cp $HWAL/colors-dunst.conf $CFG/dunst/dunstrc.d/colors.conf
cp $HWAL/colors-waybar.css $CFG/waybar/colors.css
cp $HWAL/colors.conf $CFG/hypr/colors.conf
cp $HWAL/colors.lua $CFG/hypr/colors.lua
cp $HWAL/colors-tofi $CFG/tofi/colors
