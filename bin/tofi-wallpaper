#!/usr/bin/env bash

log()   { printf "\033[1;34minfo    \033[0m %s\n" "$*"; }
error() { printf "\033[1;31merror   \033[0m %s\n" "$*"; }

WALLS=~/.cache/rice/walls
PICK=$(fdfind . "$WALLS" --type f --exec basename {} | tofi --prompt-text "")
IMG=$WALLS/$PICK

if [[ -z $PICK ]]; then
    error "pick cancelled"
    exit 1
fi

log "setting wallpaper"
awww img "$IMG" -t none
cp "$IMG" $WALLS/current
