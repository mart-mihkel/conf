#!/usr/bin/env bash

log() { printf "\033[1;34m[%s]\033[0m %s\n" "$(date '+%H:%M:%S')" "$*"; }

if [[ "${1:-}" == "--hellwal" ]]; then
    HELLWAL=true
else
    HELLWAL=false
fi

WALLPAPERS=~/.cache/rice/walls
PICK=$(ls "$WALLPAPERS" | tofi --prompt-text img:)
IMG=$WALLPAPERS/$PICK

if [[ -z $PICK ]]; then
    log "Pick cancelled"
    exit 1
fi

log "Setting wallpaper"
awww img "$IMG" \
    --transition-type random \
    --transition-duration 2 \
    --transition-fps 60 &

if ! $HELLWAL; then
    log "Skipping color generation"
    exit 0
fi

log "Generating colors"

case $PICK in
    light-*) MODE=--light ;;
    dark-*) MODE=--dark ;;
    *) MODE= ;;
esac

hellwal --quiet --skip-term-colors $MODE --image "$IMG"

cp ~/.cache/hellwal/colors-dunst.conf ~/.config/dunst/dunstrc.d/colors.conf
cp ~/.cache/hellwal/colors-waybar.css ~/.config/waybar/colors.css
cp ~/.cache/hellwal/colors.conf ~/.config/hypr/colors.conf
cp ~/.cache/hellwal/colors-tofi ~/.config/tofi/colors
