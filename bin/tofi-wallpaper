#!/usr/bin/env bash

WALLPAPERS=~/.cache/rice/walls
PICK=$(ls $WALLPAPERS | tofi --prompt-text img:)

[[ -z $PICK ]] && exit 1

case $PICK in
    light-*) MODE=--light ;;
    dark-*) MODE=--dark ;;
    *) MODE= ;;
esac

hellwal --image $WALLPAPERS/$PICK $MODE --skip-term-colors &

awww img $WALLPAPERS/$PICK \
    --transition-type random \
    --transition-duration 2 \
    --transition-fps 60
