separator=true
separator_block_width=10

[audio]
command=echo "$(pactl get-sink-mute @DEFAULT_SINK@ | grep -q yes && echo '箚뻶' || echo '箚빢')"
interval=once
signal=1

[mic]
command=echo "$(pactl get-source-mute @DEFAULT_SOURCE@ | grep -q yes && echo '箚뜭' || echo '箚뜫')"
interval=once
signal=1

[battery]
command=echo "箚겧 $(cat /sys/class/power_supply/BAT0/capacity)%"
interval=60

[time]
command=date +"箚꺉 %a, %b-%d %H:%M "
interval=2

