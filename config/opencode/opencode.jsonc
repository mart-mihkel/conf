{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Karuteene",
      "models": {
        "qwen3": {
          "name": "Qwen3.6 35B IQ2 A3B",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        }
      },
      "options": {
        "baseURL": "{env:LLAMA_API_URL}"
      }
    }
  }
}
